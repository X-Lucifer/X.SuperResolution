<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="clr-namespace:SukiUI;assembly=SukiUI"
             xmlns:xss="clr-namespace:X.SuperResolution"
             x:Class="X.SuperResolution.App"
             RequestedThemeVariant="Light">
    <Application.DataTemplates>
        <xss:ViewLocator />
    </Application.DataTemplates>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="Assets/Languages/zh-CN.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="DefaultFontFamily">avares://X.SuperResolution/Assets/JetBrainsMono.ttf#JetBrains Mono NL</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <suki:SukiTheme Locale="zh-CN" ThemeColor="Blue" />
        <Style Selector="RadioButton:pointerover">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="ToggleSwitch:pointerover">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Application.Styles>
</Application>